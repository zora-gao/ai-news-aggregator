# 本地抓取所需环境变量。复制为 .env 后填写（.env 已被 .gitignore 忽略，不会提交）。
#   cp .env.example .env

# GLM（智谱）API Key：用于生成中文标题与摘要。不填也能抓取，但新文章会缺摘要/译名。
GLM_API_KEY=

# GLM 模型，默认 glm-4.5-flash（免费）。一般无需改动。
GLM_MODEL=glm-4.5-flash

# WeWe RSS 服务地址。本机默认 http://localhost:4000，通常不用改。
# 仅当把 WeWe RSS 部署到了别的地址时才需要覆盖。
# WEWE_RSS_BASE_URL=http://localhost:4000
